<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="Portfolio">
<meta name="theme-color" content="#0b0f1a">
<link rel="apple-touch-icon" href="icon.png">
<title>Paper Portfolio</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  :root {
    --bg: #0b0f1a; --card: #161c2c; --card2: #1e2538;
    --text: #e8ecf4; --muted: #8a93a8; --border: #252c40;
    --pos: #34d399; --neg: #f87171; --accent: #34d399;
  }
  body {
    background: var(--bg); color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    min-height: 100dvh; padding-bottom: 32px;
  }
  .wrap { max-width: 480px; margin: 0 auto; padding: 20px 16px; }
  .app-title { font-size: 14px; font-weight: 600; color: var(--muted); letter-spacing: 0.5px; text-transform: uppercase; }
  .updated { font-size: 12px; color: var(--muted); margin-top: 2px; }

  .hero { text-align: center; padding: 28px 0 20px; }
  .hero-label { font-size: 13px; color: var(--muted); margin-bottom: 6px; }
  .hero-value { font-size: 44px; font-weight: 800; letter-spacing: -1px; }
  .hero-change { font-size: 16px; font-weight: 600; margin-top: 6px; }
  .hero-week { font-size: 13px; color: var(--muted); margin-top: 8px; }

  .pos { color: var(--pos); }
  .neg { color: var(--neg); }
  .muted { color: var(--muted); }

  .card { background: var(--card); border-radius: 18px; padding: 18px; margin-bottom: 14px; border: 1px solid var(--border); }
  .card-label { font-size: 12px; font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; }

  .chart { width: 100%; height: 120px; display: block; }
  .chart-empty { font-size: 13px; color: var(--muted); text-align: center; padding: 30px 10px; }

  .bench-row { display: flex; justify-content: space-around; text-align: center; margin-bottom: 14px; }
  .bench-sub { font-size: 12px; color: var(--muted); margin-bottom: 4px; }
  .bench-val { font-size: 24px; font-weight: 800; }
  .verdict { text-align: center; font-size: 15px; font-weight: 700; padding: 10px; border-radius: 12px; background: var(--card2); }

  .row { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .row:last-child { border-bottom: none; }
  .row-main { display: flex; flex-direction: column; gap: 3px; }
  .ticker { font-size: 16px; font-weight: 700; }
  .row-sub { font-size: 12px; color: var(--muted); }
  .row-right { display: flex; flex-direction: column; align-items: flex-end; gap: 3px; }
  .row-val { font-size: 15px; font-weight: 600; }
  .row-pct { font-size: 13px; font-weight: 600; }

  .trade { padding: 12px 0; border-bottom: 1px solid var(--border); }
  .trade:last-child { border-bottom: none; }
  .trade-head { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 5px; }
  .badge { font-size: 11px; font-weight: 800; padding: 2px 8px; border-radius: 6px; }
  .badge.buy { background: rgba(52,211,153,0.18); color: var(--pos); }
  .badge.sell { background: rgba(248,113,113,0.18); color: var(--neg); }
  .trade-meta { font-size: 12px; color: var(--muted); }
  .trade-reason { font-size: 13px; color: #b8c0d4; line-height: 1.45; }

  .empty { font-size: 14px; color: var(--muted); text-align: center; padding: 16px; }
  .disclaimer { font-size: 11px; color: var(--muted); text-align: center; margin-top: 18px; line-height: 1.5; }
</style>
</head>
<body>
<div class="wrap">
  <div class="app-title">Paper Portfolio</div>
  <div class="updated">Updated {{ updated_at }}</div>

  <div class="hero">
    <div class="hero-label">Total Value · started ${{ "%.0f"|format(starting_capital) }} on {{ start_date }}</div>
    <div class="hero-value">${{ "%.2f"|format(total_value) }}</div>
    <div class="hero-change {{ pl_class }}">{{ pl_sign }}{{ "%.2f"|format(pl_abs) }} ({{ pl_sign }}{{ "%.2f"|format(pl_pct_abs) }}%)</div>
    <div class="hero-week"><span class="{{ week_class }}">{{ week_sign }}{{ "%.2f"|format(week_abs) }} ({{ week_sign }}{{ "%.2f"|format(week_pct_abs) }}%)</span> this week</div>
  </div>

  <div class="card">
    <div class="card-label">Value Over Time</div>
    <div class="chart-empty">Your value chart appears here after a few days of trading.</div>
  </div>

  <div class="card">
    <div class="card-label">vs. Just Holding NVDA</div>
    <div class="bench-row">
      <div><div class="bench-sub">Your portfolio</div><div class="bench-val {{ port_pct_class }}">{{ port_pct_sign }}{{ "%.2f"|format(port_pct_abs) }}%</div></div>
      <div><div class="bench-sub">${{ "%.0f"|format(starting_capital) }} in NVDA</div><div class="bench-val {{ nvda_pct_class }}">{{ nvda_pct_sign }}{{ "%.2f"|format(nvda_pct_abs) }}%</div></div>
    </div>
    <div class="verdict {{ verdict_class }}">{{ verdict_text }}</div>
  </div>

  <div class="card">
    <div class="card-label">Holdings</div>
    {% for h in holdings %}
    <div class="row">
      <div class="row-main">
        <span class="ticker">{{ h.ticker }}</span>
        <span class="row-sub">{{ h.shares_str }} sh · avg ${{ "%.2f"|format(h.avg_cost) }}</span>
      </div>
      <div class="row-right">
        <span class="row-val">${{ "%.2f"|format(h.market_value) }}</span>
        <span class="row-pct {{ h.pl_class }}">{{ h.pl_sign }}{{ "%.2f"|format(h.pl_pct_abs) }}%</span>
      </div>
    </div>
    {% endfor %}
  </div>

  <div class="card">
    <div class="card-label">Trade History</div>
    {% for t in trades %}
    <div class="trade">
      <div class="trade-head">
        <span class="badge buy">BUY</span>
        <span class="ticker">{{ t.ticker }}</span>
        <span class="trade-meta">{{ t.shares_str }} sh @ ${{ "%.2f"|format(t.avg_cost) }} · {{ t.buy_date }}</span>
      </div>
      <div class="trade-reason">{{ t.thesis }}</div>
    </div>
    {% endfor %}
  </div>

  <div class="disclaimer">
    Paper trading only — simulated money, no brokerage involved.<br>
    Not financial advice. The NVDA line is a sanity check, not a recommendation.
  </div>
</div>
</body>
</html>
